      {"enabled": true, "extension": "EmptyDataDecls"},
      {"enabled": true, "extension": "ExistentialQuantification"},
      {"enabled": true, "extension": "ExplicitForAll"},
      {"enabled": true, "extension": "ExplicitNamespaces"},
