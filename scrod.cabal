cabal-version: 3.12
-- https://cabal.readthedocs.io/en/stable/cabal-package-description-file.html
name: scrod
version: 0.2026.1.30
synopsis: TODO
description:
  TODO
  TODO

category: Documentation
license: 0BSD
maintainer: Taylor Fausak
license-file: LICENSE.txt
extra-doc-files:
  CHANGELOG.md
  README.md

extra-source-files:
  test-data/**/*.json

source-repository head
  location: https://github.com/tfausak/scrod
  type: git

flag pedantic
  default: False
  manual: True

common library
  build-depends:
    aeson ^>=2.2.3,
    base ^>=4.20.2,
    bytestring ^>=0.12.2,
    clay ^>=0.16.1,
    containers ^>=0.7,
    ghc ^>=9.10.3,
    ghc-boot-th ^>=9.10.3,
    haddock-library ^>=1.11,
    http-client ^>=0.7.19,
    http-client-tls ^>=0.3.6,
    http-types ^>=0.12.4,
    lucid2 ^>=0.0.20250303,
    optparse-applicative ^>=0.19.0,
    scientific ^>=0.3.8,
    template-haskell ^>=2.22.0,
    text ^>=2.1.3,
    transformers ^>=0.6.1,
    vector ^>=0.13.2,

  default-language: Haskell2010
  ghc-options:
    -fmax-relevant-binds=0
    -fno-show-error-context
    -funclutter-valid-hole-fits
    -Weverything
    -Wno-all-missed-specialisations
    -Wno-implicit-prelude
    -Wno-missed-specialisations
    -Wno-missing-deriving-strategies
    -Wno-missing-export-lists
    -Wno-missing-kind-signatures
    -Wno-missing-role-annotations
    -Wno-missing-safe-haskell-mode
    -Wno-prepositive-qualified-module
    -Wno-safe
    -Wno-unsafe

  if flag(pedantic)
    ghc-options: -Werror

common executable
  import: library
  build-depends: scrod
  ghc-options:
    -rtsopts
    -threaded
    -Wno-unused-packages

-- Private sub-library for GHC integration
library scrod-ghc
  build-depends:
    base ^>=4.20.2,
    containers ^>=0.7,
    ghc ^>=9.10.3,
    ghc-boot-th ^>=9.10.3,
    template-haskell ^>=2.22.0,

  default-language: Haskell2010
  ghc-options:
    -fmax-relevant-binds=0
    -fno-show-error-context
    -funclutter-valid-hole-fits
    -Weverything
    -Wno-all-missed-specialisations
    -Wno-implicit-prelude
    -Wno-missed-specialisations
    -Wno-missing-deriving-strategies
    -Wno-missing-export-lists
    -Wno-missing-kind-signatures
    -Wno-missing-role-annotations
    -Wno-missing-safe-haskell-mode
    -Wno-prepositive-qualified-module
    -Wno-safe
    -Wno-unsafe

  if flag(pedantic)
    ghc-options: -Werror
  hs-source-dirs: source/library
  exposed-modules:
    Scrod.Exception.Uninitialized
    Scrod.Extra.ArchOS
    Scrod.Extra.DynFlags
    Scrod.Extra.FileSettings
    Scrod.Extra.GhcNameVersion
    Scrod.Extra.Natural
    Scrod.Extra.OnOff
    Scrod.Extra.ParserOpts
    Scrod.Extra.Platform
    Scrod.Extra.PlatformMisc
    Scrod.Extra.ToolSettings
    Scrod.Parse

  visibility: private

-- Private sub-library for core types (no JSON/HTML)
