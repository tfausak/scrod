      {"enabled": true, "extension": "FlexibleInstances"},
      {"enabled": true, "extension": "ForeignFunctionInterface"},
      {"enabled": true, "extension": "FunctionalDependencies"},
      {"enabled": true, "extension": "GeneralizedNewtypeDeriving"},
      {"enabled": true, "extension": "ImplicitParams"},
      {"enabled": true, "extension": "KindSignatures"},
