    -Wno-missing-role-annotations
    -Wno-missing-safe-haskell-mode
    -Wno-prepositive-qualified-module
    -Wno-safe
    -Wno-unsafe

  if flag(pedantic)
    ghc-options: -Werror
  hs-source-dirs: source/library
  exposed-modules:
    Scrod.Convert
    Scrod.Type.Category
    Scrod.Type.Column
    Scrod.Type.ConversionState
    Scrod.Type.Doc
    Scrod.Type.Example
    Scrod.Type.Export
    Scrod.Type.ExportIdentifier
    Scrod.Type.ExportName
    Scrod.Type.ExportNameKind
    Scrod.Type.Extension
