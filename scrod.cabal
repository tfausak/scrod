  build-depends:
    aeson ^>=2.2.3,
    base ^>=4.20.2,
    bytestring ^>=0.12.2,
    clay ^>=0.16.1,
    containers ^>=0.7,
    ghc ^>=9.10.3,
    ghc-boot-th ^>=9.10.3,
    haddock-library ^>=1.11,
    http-client ^>=0.7.19,
    http-client-tls ^>=0.3.6,
