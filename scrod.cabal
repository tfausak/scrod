test-suite scrod-test-suite
  import: executable
  build-depends:
    directory ^>=1.3.8,
    filepath ^>=1.5.4,
    tasty ^>=1.5.3,
    tasty-hunit ^>=0.10.2,

  hs-source-dirs: source/test-suite
  main-is: Main.hs
  other-modules:
    JsonSpec
    Pointer
    Spec

  type: exitcode-stdio-1.0

executable scrod
  import: executable
  hs-source-dirs: source/executable
  main-is: Main.hs
